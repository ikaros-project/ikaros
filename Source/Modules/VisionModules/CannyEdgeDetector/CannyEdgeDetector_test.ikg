   <widget _index_="4" _x="600" _y="528" class="slider-horizontal" count="1" frame-style="" height="73" labels="" max="0.2" min="0" name="Widget_3" parameter="EdgeDetector.low_threshold" select="0" show_frame="false" show_title="true" show_values="false" source="" step="0.001" style="" title="Lower" width="217"/>
