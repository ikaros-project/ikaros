   <module _x="336" _y="720" class="SobelEdgeDetector" name="Sobel" sigma="1"/>
   <widget _index_="0" _x="24" _y="72" class="image" command="" file="" flipXAxis="no" flipXCanvas="no" flipYAxis="no" flipYCanvas="no" format="rgb" frame-style="" height="433" index="" max="1" max_x="1" max_y="1" min="0" min_x="0" min_y="0" module="" name="Widget_1" opacity="1" opacity_source="" scale="both" scales="no" select="" show_frame="true" show_title="false" source="Video.OUTPUT" style="" title="Input" width="553"/>
