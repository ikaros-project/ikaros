<group log_level="6" auto_routing="false" name="Statistics_test" tick_duration="1" grid_spacing="24">
   <parameter value="6" options="inherit,quiet,exception,end_of_file,terminate,fatal_error,warning,print,debug,trace" type="number" control="menu" default="0" name="log_level"/>
   <parameter value="0" options="at_tick,first_data,all_data" type="number" control="menu" default="0" name="module_start"/>
   <parameter value="0" name="start_tick" default="0" type="number"/>
   <module _x="24" name="Values" data="1, 10, 4" class="Constant" _y="72"/>
   <module _x="192" max="1" type="gaussian" stddev="12" class="Noise" _y="96" min="-1" name="Noise"/>
   <module _x="24" name="Sample" data="1, 1, 1" class="Constant" _y="216"/>
   <module _x="384" group_test="parametric" class="Statistics" labels="A,B,C&#10;" _y="144" pairwise_test="parametric" p_adjustment="holm" bins="50" module_start="all_data" name="Statistics"/>
   <widget outlierRadius="3" name="BoxPlot" yAxisLabel="Value&#10;" title="Box Plot" outlierSource="Statistics.BOX_PLOT_OUTLIERS" show_title="true" width="433" lineWidth="1" min="0" show_frame="true" height="601" source="Statistics.BOX_PLOT" class="boxplot" style="" auto="true" _y="24" _index_="0" drawLabelsX="true" direction="vertical" horizontalGridlines="5" frame-style="" xAxisLabel="Channel" max="4" _x="1560" fill="red, green,blue" background="" yAxis="true" frame_width="1" color="&#10;" include_zero="false" leftTickMarks="5" leftScale="5" decimals="2" labels="&#10;" frame_color=""/>
   <widget include_zero="true" frame_width="2" frame_color="black" background="#ffe&#10;&#10;" direction="vertical" class="bar-graph" source="Statistics.MEDIAN" show_title="true" frame-style="" min="0" lineCap="" fill="red, green, blue" style="" auto="true" show_frame="true" height="217" lineWidth="1" width="241" lineJoin="" transpose="false" _x="384" max="1" _y="864" _index_="2" labels="A,B,C" color="" title="MEDIAN" name="Widget_1"/>
   <widget frame_color="" height="601" show_frame="true" auto="true" style="" max="1" _x="648" spaceRight="4" transpose="false" marginTop="4" background="" bottomScale="5" source="Statistics.HISTOGRAM" class="histogram" lineCap="" leftTickMarks="5" fill="#ccc" min="0" meanSource="Statistics.MEAN" xAxis="true" select="" lineJoin="" width="889" include_zero="false" horizontalGridlines="2" stdevSource="Statistics.STANDARD_DEVIATION" direction="vertical" marginRight="4" _y="24" marginBottom="4" curveColor="red" title="Statistics.HISTOGRAM" _index_="4" yAxis="true" show_title="true" marginLeft="4" leftScale="5" spaceLeft="4" spaceTop="4" frame-style="" yAxisLabel="Channel&#10;" histogramMaxSource="Statistics.HISTOGRAM_MAX" lineWidth="1" xAxisLabel="Value" labels="&#10;" spaceBottom="4" decimals="2" bottomTickMarks="24" color="&#10;" frame_width="1" name="Widget_2" histogramMinSource="Statistics.HISTOGRAM_MIN"/>
   <widget name="Widget_3" label_x="&#10;" width="433" show_title="true" title="Pairwise p-value" frame_width="1" style="" _index_="6" _y="864" max="1" _x="1560" height="121" scrollable="false" show_frame="true" label_y="&#10;" min="0" background="" colorize="true" select="" source="Statistics.PAIRWISE_TEST_P" class="table" direction="normal" decimals="4" frame_color="" frame-style=""/>
   <widget name="Widget_31" label_x="&#10;" width="433" show_title="true" title="Adjusted p-value" frame_width="1" style="" _index_="8" _y="1008" max="1" _x="1560" height="145" scrollable="false" show_frame="true" label_y="&#10;" min="0" background="" colorize="true" select="" source="Statistics.PAIRWISE_TEST_P_ADJUSTED" class="table" direction="normal" decimals="4" frame_color="" frame-style=""/>
   <widget name="Widget_311" label_x="" width="313" show_title="true" title="Group Test (ANOVA)" frame_width="1" style="" _index_="10" _y="648" max="1" _x="1224" height="433" scrollable="false" show_frame="true" label_y="" min="0" background="" colorize="true" select="" source="Statistics.GROUP_TEST" class="table" direction="normal" decimals="0" frame_color="" frame-style=""/>
   <widget name="Widget_3111" label_x="&#10;" width="433" show_title="true" title="Box Plot Data" frame_width="1" style="" _index_="12" _y="648" max="1" _x="1560" height="193" scrollable="false" show_frame="true" label_y=" " min="0" background="" colorize="true" select="" source="Statistics.BOX_PLOT" class="table" direction="normal" decimals="4" frame_color="" frame-style=""/>
   <widget name="Widget_31111" label_x="&#10;" width="553" show_title="true" title="Summary Statistics" frame_width="1" style="" _index_="14" _y="648" max="1" _x="648" height="289" scrollable="false" show_frame="true" label_y=" " min="0" background="" colorize="true" select="" source="Statistics.OUTPUT" class="table" direction="normal" decimals="4" frame_color="" frame-style=""/>
   <widget name="Widget_311111" label_x="&#10;" width="553" show_title="true" title="Normality Test" frame_width="1" style="" _index_="16" _y="960" max="1" _x="648" height="289" scrollable="false" show_frame="true" label_y=" " min="0" background="" colorize="true" select="" source="Statistics.NORMALITY_TEST" class="table" direction="normal" decimals="4" frame_color="" frame-style=""/>
   <connection target="Noise.INPUT" source="Values.OUTPUT" line_type="auto_route"/>
   <connection target="Statistics.INPUT" source="Noise.OUTPUT" line_type="auto_route"/>
</group>
