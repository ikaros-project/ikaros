<group name="World2D_Test" start="true" stop="-1" tick_duration="0.05" webui_port="8022">
    <module name="Motor" class="Constant" data="0.04, 0.07" />
    <module name="World" class="World2D"
        aversive="3,210,85,10,-1,0.85,0.20,0.18,0,0,0,0,0,0,0,0,1; 4,112,120,12,-1,0.48,0.48,0.50,0,0,0,0,0,0,0,0,1; 5,172,160,16,-1,0.48,0.48,0.50,0,0,0,0,0,0,0,0,1; 6,95,220,14,-1,0.48,0.48,0.50,0,0,0,0,0,0,0,0,1; 7,245,150,11,-1,0.48,0.48,0.50,0,0,0,0,0,0,0,0,1"
        walls="8,50,45,250,45,0.18,0.18,0.18,1,2,1; 9,50,255,250,255,0.18,0.18,0.18,1,2,1; 10,50,45,50,255,0.18,0.18,0.18,1,2,1; 11,250,45,250,255,0.18,0.18,0.18,1,2,1; 12,125,75,125,185,0.18,0.18,0.18,1,3,0; 13,175,115,230,115,0.18,0.18,0.18,1,3,1" />

    <connection source="Motor.OUTPUT" target="World.MOTOR" />

    <widget name="WorldView" class="world2d" creature_source="World.CREATURE" objects_source="World.OBJECTS" walls_source="World.WALLS" whiskers_source="World.WHISKERS" tool_parameter="World.edit_tool" whisker_length_parameter="World.whisker_length" whisker_angle_parameter="World.whisker_angle" width="560" height="560" x="520" y="60" _x="520" _y="60" title="World2D" show_title="true" show_frame="true" world_width="300" world_height="300" grid_step="10" whisker_length="10" whisker_angle="0.7853981633974483" />
    <widget name="ToolSelect" class="button" parameter="World.edit_tool" type="radio" radioGroup="World2DTools" label="Select" icon="Images/world2d-pointer.svg" value="0" valueUp="0" select_x="0" select_y="0" show_title="false" show_frame="false" width="42" height="34" x="520" y="625" _x="520" _y="625" />
    <widget name="ToolAddObject" class="button" parameter="World.edit_tool" type="radio" radioGroup="World2DTools" label="Add object" icon="Images/world2d-circle.svg" value="1" valueUp="0" select_x="0" select_y="0" show_title="false" show_frame="false" width="42" height="34" x="566" y="625" _x="566" _y="625" />
    <widget name="ToolAddWall" class="button" parameter="World.edit_tool" type="radio" radioGroup="World2DTools" label="Add wall" icon="Images/world2d-line.svg" value="2" valueUp="0" select_x="0" select_y="0" show_title="false" show_frame="false" width="42" height="34" x="612" y="625" _x="612" _y="625" />
    <widget name="ToolDelete" class="button" parameter="World.edit_tool" type="radio" radioGroup="World2DTools" label="Delete" icon="Images/world2d-eraser.svg" value="3" valueUp="0" select_x="0" select_y="0" show_title="false" show_frame="false" width="42" height="34" x="658" y="625" _x="658" _y="625" />
    <widget name="WheelSpeed" class="slider-horizontal" parameter="Motor.data" select_x="0" count="2" labels="Left wheel, Right wheel" min="-0.25" max="0.25" step="0.01" show_values="true" show_title="true" show_frame="false" title="Wheel speeds" width="420" height="80" x="60" y="640" _x="60" _y="640" />
    <widget name="EditType" class="drop-down-menu" parameter="World.edit_type" enableSource="World.EDIT_OBJECT_ENABLE" parameter_type="number" list="Food,Aversive" label="Type" labelWidth="45" show_title="false" show_frame="false" title="Edit type" width="200" height="40" x="60" y="740" _x="60" _y="740" />
    <widget name="EditOpaque" class="switch" parameter="World.edit_opaque" enableSource="World.EDIT_WALL_ENABLE" select_x="0" select_y="" count="1" labels="Opaque" value="1" show_title="false" show_frame="false" title="Edit opaque" width="140" height="40" x="280" y="740" _x="280" _y="740" />
    <widget name="EditValue" class="slider-horizontal" parameter="World.edit_value" enableSource="World.EDIT_OBJECT_ENABLE" select_x="0" count="1" labels="Value" min="-1" max="1" step="0.01" show_values="true" show_title="true" show_frame="false" title="Edit value" width="420" height="70" x="60" y="790" _x="60" _y="790" />
    <widget name="EditColor" class="slider-horizontal" parameter="World.edit_color" enableSource="World.EDIT_COLOR_ENABLE" select_x="0" count="3" labels="Red, Green, Blue" min="0" max="1" step="0.01" show_values="true" show_title="true" show_frame="false" title="Edit color" width="420" height="110" x="60" y="880" _x="60" _y="880" />
    <widget name="EditSmell" class="slider-horizontal" parameter="World.edit_smell" enableSource="World.EDIT_OBJECT_ENABLE" select_x="0" count="8" labels="Smell 1, Smell 2, Smell 3, Smell 4, Smell 5, Smell 6, Smell 7, Smell 8" min="0" max="1" step="0.01" show_values="true" show_title="true" show_frame="false" title="Edit smell" width="420" height="180" x="60" y="1010" _x="60" _y="1010" />
    <widget name="Pose" class="table" source="World.POSE" width="220" height="90" x="1100" y="60" _x="1100" _y="60" title="POSE" show_title="true" show_frame="true" decimals="2" />
    <widget name="Contact" class="table" source="World.CONTACT" width="220" height="90" x="1100" y="180" _x="1100" _y="180" title="CONTACT" show_title="true" show_frame="true" decimals="0" />
