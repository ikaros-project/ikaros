<group name="Integrator_test" start="true" stop="4">
    <module class="TimeSeries" name="Input" data="1; 1; 1; 1" base_duration="1" loop="false" />
    <module class="Integrator" name="Integrator" alpha="1" beta="1" max="3" />
    <module class="Print" name="PrintOutput" />

    <connection source="Input.OUTPUT" target="Integrator.INPUT" delay="0" />
    <connection source="Integrator.OUTPUT" target="PrintOutput.INPUT" delay="0" />
</group>
