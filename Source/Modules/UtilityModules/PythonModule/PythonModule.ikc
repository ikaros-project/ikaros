<class name="PythonModule" description="runtime module used for python-backed class definitions">
    <parameter name="timeout_ms" type="number" default="1000" description="Maximum time budget for one python tick call." />
    <parameter name="on_error" type="string" default="pause" description="Action to take when python execution fails." />
    <parameter name="restart_on_crash" type="bool" default="false" description="Restart the python worker after a crash." />
    <parameter name="process_mode" type="string" default="worker" description="Runtime mode for the python implementation." />
    <parameter name="execution_mode" type="string" default="sync" description="Execution policy for the python implementation." />
    <parameter name="python_executable" type="string" default="python3" description="Python interpreter used in worker mode." />
</class>
