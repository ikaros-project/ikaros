<group name="XorTest" >
   <module class="Constant" data="0, 1; 2, 0" name="Constant1" />
   <module class="Constant" data="1, 1; 0, 0" name="Constant2" />
   <module class="Xor" description="computes the element-wise logical xor of two inputs" name="Xor" />
   <module class="Print" name="Print"/>

   <connection source="Constant1.OUTPUT" target="Xor.INPUT1" delay="0" />
   <connection source="Constant2.OUTPUT" target="Xor.INPUT2" delay="2" />
   <connection source="Xor.OUTPUT" target="Print.INPUT" delay="0" />

</group>
