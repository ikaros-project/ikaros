<group name="MinimumTest" >
   <module class="Constant" data="1, 5; 3, 4" name="Constant1" />
   <module class="Constant" data="8, 2; 10, 1" name="Constant2" />
   <module class="Minimum" description="takes the element-wise minimum of two inputs" name="Minimum" />
   <module class="Print" name="Print"/>

   <connection source="Constant1.OUTPUT" target="Minimum.INPUT1" delay="0" />
   <connection source="Constant2.OUTPUT" target="Minimum.INPUT2" delay="2" />
   <connection source="Minimum.OUTPUT" target="Print.INPUT" delay="0" />

</group>
