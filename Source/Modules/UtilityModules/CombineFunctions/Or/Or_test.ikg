<group name="OrTest" >
   <module class="Constant" data="0, 1; 2, 0" name="Constant1" />
   <module class="Constant" data="1, 0; 0, 3" name="Constant2" />
   <module class="Or" description="computes the element-wise logical or of two inputs" name="Or" />
   <module class="Print" name="Print"/>

   <connection source="Constant1.OUTPUT" target="Or.INPUT1" delay="0" />
   <connection source="Constant2.OUTPUT" target="Or.INPUT2" delay="2" />
   <connection source="Or.OUTPUT" target="Print.INPUT" delay="0" />

</group>
