<group name="ConvolutionalVariationalAutoEncoder_test">
	<module class="Constant" name="Image" _x="40" _y="40" data="0, 0.2, 0.4, 0.6; 0.2, 0.4, 0.6, 0.8; 0.4, 0.6, 0.8, 1; 0.6, 0.8, 1, 0.8" />
	<module class="ConvolutionalVariationalAutoEncoder" name="CVAE" _x="300" _y="40" latent_size="2" feature_maps="2" kernel_size="2" learning_rate="0.001" beta="0.1" train="yes" sample="no" />
	<module class="Print" name="PrintLoss" _x="560" _y="40" />
	<connection source="Image.OUTPUT" target="CVAE.INPUT" />
	<connection source="CVAE.LOSS" target="PrintLoss.INPUT" />
	<widget class="image" name="InputImage" title="Input" source="Image.OUTPUT" format="gray" x="40" y="200" width="260" height="220" min="0" max="1" scale="both" show_title="true" show_frame="true"  _x="40" _y="200" />
	<widget class="image" name="ReconstructionImage" title="Reconstruction" source="CVAE.OUTPUT" format="gray" x="340" y="200" width="260" height="220" min="0" max="1" scale="both" show_title="true" show_frame="true"  _x="340" _y="200" />
	<widget class="bar-graph" name="LatentMean" title="Latent Mean" source="CVAE.LATENT_MEAN" x="640" y="200" width="260" height="220" min="-2" max="2" show_title="true" show_frame="true"  _x="640" _y="200" />
	<widget class="plot" name="LossPlot" title="Loss" source="CVAE.LOSS" x="40" y="460" width="260" height="160" min="0" max="1" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="100"  _x="40" _y="460" />
	<widget class="plot" name="ReconstructionLossPlot" title="Reconstruction Loss" source="CVAE.RECONSTRUCTION_LOSS" x="340" y="460" width="260" height="160" min="0" max="1" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="100"  _x="340" _y="460" />
	<widget class="plot" name="KLLossPlot" title="KL Loss" source="CVAE.KL_LOSS" x="640" y="460" width="260" height="160" min="0" max="1" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="100"  _x="640" _y="460" />
</group>
