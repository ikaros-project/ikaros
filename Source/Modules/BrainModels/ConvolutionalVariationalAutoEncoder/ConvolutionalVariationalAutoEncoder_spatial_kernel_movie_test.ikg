<group name="ConvolutionalVariationalAutoEncoder_spatial_kernel_movie_test" title="Convolutional VAE Spatial Kernel Movie Example">
	<module
		class="InputVideoFile"
		name="Movie"
		_x="40"
		_y="40"
		filename="../Source/Modules/IOModules/FileInput/InputVideoFile/ikaros.mp4"
		loop="true"
		size_x="32"
		size_y="24"
	/>

	<module
		class="ConvolutionalVariationalAutoEncoder"
		name="CVAE"
		_x="340"
		_y="40"
		latent_mode="spatial"
		latent_maps="4"
		latent_kernel_size="2"
		feature_maps="8"
		kernel_size="3"
		learning_rate="0.001"
		beta="0.001"
		train="yes"
		train_interval="4"
		dense_train_interval="2"
		sample="no"
	/>

	<connection source="Movie.INTENSITY" target="CVAE.INPUT" />

	<widget class="image" name="InputImage" title="Movie Input" source="Movie.INTENSITY" format="gray" x="40" y="200" width="320" height="240" min="0" max="1" scale="both" show_title="true" show_frame="true"  _x="40" _y="200" />
	<widget class="image" name="ReconstructionImage" title="Spatial CVAE Reconstruction" source="CVAE.OUTPUT" format="gray" x="400" y="200" width="320" height="240" min="0" max="1" scale="both" show_title="true" show_frame="true"  _x="400" _y="200" />
	<widget class="table" name="LatentMeanTable" title="Latent Mean" source="CVAE.LATENT_MEAN" x="760" y="200" width="320" height="140" decimals="3" show_title="true" show_frame="true" colorize="true"  _x="760" _y="200" />
	<widget class="table" name="LatentSampleTable" title="Latent Sample" source="CVAE.LATENT_SAMPLE" x="760" y="380" width="320" height="140" decimals="3" show_title="true" show_frame="true" colorize="true"  _x="760" _y="380" />
	<widget class="plot" name="LossPlot" title="Loss" source="CVAE.LOSS" x="40" y="500" width="320" height="180" min="0" max="1" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="100"  _x="40" _y="500" />
	<widget class="plot" name="ReconstructionLossPlot" title="Reconstruction Loss" source="CVAE.RECONSTRUCTION_LOSS" x="400" y="500" width="320" height="180" min="0" max="1" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="100"  _x="400" _y="500" />
	<widget class="plot" name="KLLossPlot" title="KL Loss" source="CVAE.KL_LOSS" x="760" y="560" width="320" height="180" min="0" max="1" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="100"  _x="760" _y="560" />
</group>
