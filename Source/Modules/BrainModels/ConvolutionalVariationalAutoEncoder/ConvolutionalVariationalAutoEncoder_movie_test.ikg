<group name="ConvolutionalVariationalAutoEncoder_movie_test" title="Convolutional VAE Movie Example">
	<module
		class="InputVideoFile"
		name="Movie"
		filename="../Source/Modules/IOModules/FileInput/InputVideoFile/ikaros.mp4"
		loop="true"
		size_x="32"
		size_y="24"
	/>

	<module
		class="ConvolutionalVariationalAutoEncoder"
		name="CVAE"
		latent_size="32"
		feature_maps="12"
		kernel_size="3"
		learning_rate="0.001"
		beta="0.001"
		train="yes"
		train_interval="4"
		sample="no"
	/>

	<connection source="Movie.INTENSITY" target="CVAE.INPUT" />

	<widget class="image" name="InputImage" title="Movie Input" source="Movie.INTENSITY" format="gray" x="40" y="40" width="320" height="240" min="0" max="1" scale="both" show_title="true" show_frame="true" />
	<widget class="image" name="ReconstructionImage" title="CVAE Reconstruction" source="CVAE.OUTPUT" format="gray" x="400" y="40" width="320" height="240" min="0" max="1" scale="both" show_title="true" show_frame="true" />
	<widget class="plot" name="LossPlot" title="Loss" source="CVAE.LOSS" x="40" y="320" width="320" height="180" min="0" max="1" show_title="true" show_frame="true" />
	<widget class="bar-graph" name="LatentMean" title="Latent Mean" source="CVAE.LATENT_MEAN" x="400" y="320" width="320" height="180" min="-2" max="2" show_title="true" show_frame="true" />
</group>
