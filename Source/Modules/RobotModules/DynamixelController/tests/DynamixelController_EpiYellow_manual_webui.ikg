<group log_level="6" auto_routing="false" real_time="true" stop="-1" name="DynamixelControllerEpiYellowManualWebUI" info="true" tick_duration="0.025" _pane_layout="{&quot;version&quot;:1,&quot;network&quot;:&quot;DynamixelControllerEpiYellowManualWebUI&quot;,&quot;tree&quot;:{&quot;type&quot;:&quot;pane&quot;,&quot;background&quot;:&quot;DynamixelControllerEpiYellowManualWebUI&quot;,&quot;active&quot;:true}}" webui_port="8080" grid_spacing="24" hide_toolbar="false">
