<group name="example" title="InputVideoStream Local Example">
    <module
        class = "InputVideoStream"
        name = "InputVideoStream"
        url = "../Source/Modules/IOModules/FileInput/InputVideoFile/ikaros.mp4"
        uv4l = "false"
        synchronized_framegrabber = "false"
        synchronized_tick = "true"
        size_x = "148"
        size_y = "108"
    />

    <widget class="image"
        max_x = "1"
        title = "Intensity"
        width = "381"
        flipYCanvas = "no"
        x = "460"
        source = "InputVideoStream.INTENSITY"
        format = "gray"
        flipYAxis = "no"
        flipXCanvas = "no"
        h = "4"
        height = "321"
        max_y = "1"
        y = "60"
        flipXAxis = "no"
        scale = "both"
        scales = "no"
        w = "4"
    />
</group>
