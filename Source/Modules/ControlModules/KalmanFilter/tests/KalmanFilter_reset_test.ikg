<group name="KalmanFilter_reset_test" start="true" stop="1">
    <module class="Constant" name="Observation" data="[1]" />
    <module class="Constant" name="Reset" data="[1]" />
    <module class="KalmanFilter" name="KalmanFilter" A="[[1]]" H="[[1]]" INITIAL_STATE="[2]" INITIAL_P="[[3]]" />
    <module class="Print" name="PrintState" />

    <connection source="Observation.OUTPUT" target="KalmanFilter.OBSERVATION" delay="0" />
    <connection source="Reset.OUTPUT" target="KalmanFilter.RESET" delay="0" />
    <connection source="KalmanFilter.STATE" target="PrintState.INPUT" delay="0" />
</group>
