<group name="KalmanFilter_test" start="true" stop="1">
    <module class="Constant" name="Input" data="[0]" />
    <module class="Constant" name="Observation" data="[1]" />
    <module class="KalmanFilter" name="KalmanFilter" process_noise="1" observation_noise="1" A="[[1]]" B="[[0]]" H="[[1]]" P="[[1]]" />
    <module class="Print" name="PrintState" />

    <connection source="Input.OUTPUT" target="KalmanFilter.INPUT" delay="0" />
    <connection source="Observation.OUTPUT" target="KalmanFilter.OBSERVATION" delay="0" />
    <connection source="KalmanFilter.STATE" target="PrintState.INPUT" delay="0" />
</group>
