<group name="KalmanFilter_full_noise_test" start="true" stop="1">
    <module class="Constant" name="Observation" data="[1]" />
    <module class="KalmanFilter" name="KalmanFilter" process_noise="100" observation_noise="100" A="[[1]]" H="[[1]]" P="[[1]]" Q="[[0.5]]" R="[[2]]" />
    <module class="Print" name="PrintState" />

    <connection source="Observation.OUTPUT" target="KalmanFilter.OBSERVATION" delay="0" />
    <connection source="KalmanFilter.STATE" target="PrintState.INPUT" delay="0" />
</group>
