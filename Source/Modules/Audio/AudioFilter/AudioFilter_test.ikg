<group name="AudioFilterTest" sample_rate="10000" tick_duration="0.1" real_time="true">
   <module class="TimeSeries" name="Notes" base_duration="0.25" loop="true" data="110; 146.832384; 164.813778; 220" />
   <module class="TimeSeries" name="Gate" base_duration="0.25" loop="true" data="1; 0; 1; 0" />
   <module class="AudioOscillator" name="Oscillator" sample_rate="10000" wave_shape="saw" />
   <module class="ADSREnvelope" name="Envelope" sample_rate="10000" attack="0.01" decay="0.12" sustain="0.35" release="0.18" />
   <module class="AudioFilter" name="Filter" sample_rate="10000" cutoff="180" resonance="0.7" envelope_amount="4.5" />
   <module class="Multiply" name="VCA" />
   <module class="AudioOutput" name="AudioOutput" />

   <connection source="Notes.OUTPUT" target="Oscillator.INPUT" delay="0" />
   <connection source="Gate.OUTPUT" target="Envelope.GATE" delay="0" />
   <connection source="Gate.TRIG" target="Envelope.TRIG" delay="0" />

   <connection source="Oscillator.OUTPUT" target="Filter.INPUT" delay="0" />
   <connection source="Envelope.OUTPUT" target="Filter.CUTOFF_MOD" delay="0" />

   <connection source="Filter.OUTPUT" target="VCA.INPUT1" delay="0" />
   <connection source="Envelope.OUTPUT" target="VCA.INPUT2" delay="0" />
   <connection source="VCA.OUTPUT" target="AudioOutput.INPUT" delay="0" />

   <widget name="EnvelopePlot" class="plot" source="Envelope.OUTPUT" width="250" height="180" _x="40" _y="40" title="Envelope" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="50" direction="vertical" />
   <widget name="FilterPlot" class="plot" source="Filter.OUTPUT" width="250" height="180" _x="320" _y="40" title="Filtered" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="50" direction="vertical" />
   <widget name="SignalPlot" class="plot" source="VCA.OUTPUT" width="250" height="180" _x="600" _y="40" title="VCA" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="50" direction="vertical" />
   <widget name="NotePlot" class="plot" source="Notes.OUTPUT" width="250" height="180" _x="880" _y="40" title="Note" show_title="true" show_frame="true" auto="true" include_zero="true" buffer_size="50" direction="vertical" />

   <widget name="OscWaveShape" class="slider-horizontal" parameter="Oscillator.wave_shape" title="Osc Wave" labels="" source="" select="0" count="1" min="0" max="5" step="1" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="40" _y="280" />
   <widget name="OscMultiplier" class="slider-horizontal" parameter="Oscillator.multiplier" title="Osc Mult" labels="" source="" select="0" count="1" min="0.25" max="4" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="320" _y="280" />
   <widget name="OscDetune" class="slider-horizontal" parameter="Oscillator.detune" title="Osc Detune" labels="" source="" select="0" count="1" min="-100" max="100" step="0.1" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="600" _y="280" />
   <widget name="OscVolume" class="slider-horizontal" parameter="Oscillator.volume" title="Osc Volume" labels="" source="" select="0" count="1" min="0" max="1" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="880" _y="280" />
   <widget name="OscModGain" class="slider-horizontal" parameter="Oscillator.modulation_gain" title="Osc Mod Gain" labels="" source="" select="0" count="1" min="0" max="10" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="40" _y="340" />
   <widget name="OscDuty" class="slider-horizontal" parameter="Oscillator.duty_cycle" title="Pulse Width" labels="" source="" select="0" count="1" min="0.01" max="0.99" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="320" _y="340" />

   <widget name="EnvAttack" class="slider-horizontal" parameter="Envelope.attack" title="Attack" labels="" source="" select="0" count="1" min="0" max="2" step="0.001" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="40" _y="440" />
   <widget name="EnvDecay" class="slider-horizontal" parameter="Envelope.decay" title="Decay" labels="" source="" select="0" count="1" min="0" max="2" step="0.001" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="320" _y="440" />
   <widget name="EnvSustain" class="slider-horizontal" parameter="Envelope.sustain" title="Sustain" labels="" source="" select="0" count="1" min="0" max="1" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="600" _y="440" />
   <widget name="EnvRelease" class="slider-horizontal" parameter="Envelope.release" title="Release" labels="" source="" select="0" count="1" min="0" max="2" step="0.001" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="880" _y="440" />

   <widget name="FilterCutoff" class="slider-horizontal" parameter="Filter.cutoff" title="Cutoff Hz" labels="" source="" select="0" count="1" min="20" max="4000" step="1" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="40" _y="540" />
   <widget name="FilterResonance" class="slider-horizontal" parameter="Filter.resonance" title="Resonance" labels="" source="" select="0" count="1" min="0" max="1.2" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="320" _y="540" />
   <widget name="FilterEnvAmount" class="slider-horizontal" parameter="Filter.envelope_amount" title="Env Amount" labels="" source="" select="0" count="1" min="-4" max="6" step="0.01" show_title="true" show_values="true" show_frame="false" frame-style="" style="" width="260" height="49" _x="600" _y="540" />
</group>
