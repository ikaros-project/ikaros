<class name="AudioOutput" description="Plays audio received as input">
    <input name="INPUT" description="Audio buffer to play"/>
    <parameter name="sample_rate" type="number" default="44100" description="Sample rate of the audio" />
    <parameter name="buffer_size" type="number" default="@sample_rate*@tick_duration" description="Size of the audio buffer" />
</class>
