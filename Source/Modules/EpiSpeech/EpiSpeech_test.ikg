<group filename="" name="EpiSpeech" title="EpiSpeech Example">
   <connection source="Command.OUTPUT" target="EpiSpeech.TRIG"/>
   <connection source="Inhibition.OUTPUT" target="EpiSpeech.INHIBITION"/>
   <connection source="Attribute1.OUTPUT" target="EpiSpeech.ATTRIBUTE1"/>
   <connection source="Attribute2.OUTPUT" target="EpiSpeech.ATTRIBUTE2"/>
   <module _x="24" _y="96" class="Constant" data="0, 0, 0, 0, 0, 0" description="outputs a constant value" name="Command"/>
   <module _x="24" _y="240" class="Constant" data="0, 0, 0" description="outputs a constant value" name="Attribute1"/>
   <module _x="24" _y="312" class="Constant" data="0.5" description="outputs a constant value" name="Attribute2"/>
   <module _x="24" _y="168" class="Constant" data="0" description="outputs a constant value" name="Inhibition"/>
   <module _x="312" _y="144" class="EpiSpeech" description="reads a text using Apple's speech synthesis" name="EpiSpeech" text="one,two,three,111, robotic beings rule the world, the humans are dead." voice="Noelle (Enhanced)"/>
   <view name="Controls">
      <bar-graph auto="false" color="" direction="vertical" fill="" frame-style="" height="201" labels="" lineCap="" lineJoin="" lineWidth="1" max="1" min="0" module="Command" show_frame="false" show_title="true" source="Command.OUTPUT" style="" title="Sound Triggers" transpose="false" w="3" width="701" x="60" y="20"/>
      <bar-graph auto="false" color="" direction="vertical" fill="" frame-style="" height="200" labels="" lineCap="" lineJoin="" lineWidth="1" max="5" min="-100" show_frame="false" show_title="true" source="EpiSpeech.RMS" style="" title="VU" transpose="false" width="200" x="780" y="20"/>
      <bar-graph auto="false" color="" direction="vertical" fill="" frame-style="" height="200" labels="" lineCap="" lineJoin="" lineWidth="1" max="0.03" min="0" show_frame="false" show_title="true" source="EpiSpeech.VOLUME" style="" title="VOLUME" transpose="false" width="200" x="780" y="240"/>
      <bar-graph auto="false" color="" direction="vertical" fill="" frame-style="" height="201" labels="" lineCap="" lineJoin="" lineWidth="1" max="1" min="0" module="Command" show_frame="false" show_title="true" source="EpiSpeech.PLAYING" style="" title="Playing" transpose="false" w="3" width="701" x="60" y="480"/>
      <bar-graph auto="false" color="" direction="vertical" fill="" frame-style="" height="201" labels="" lineCap="" lineJoin="" lineWidth="1" max="1" min="0" module="Command" show_frame="false" show_title="true" source="EpiSpeech.COMPLETED" style="" title="Completed" transpose="false" w="3" width="701" x="60" y="700"/>
      <bar-graph auto="false" color="" direction="vertical" fill="" frame-style="" height="201" labels="" lineCap="" lineJoin="" lineWidth="1" max="1" min="0" module="Command" show_frame="false" show_title="true" source="EpiSpeech.ACTIVE" style="" title="Active" transpose="false" w="3" width="181" x="780" y="600"/>
      <button command="" commandUp="" enableSource="" frame-style="" label="phrase-1" parameter="Command.data" show_frame="false" show_title="false" style="" title="Title" value="1" valueUp="0" x="60" select_x="0" y="240" select_y="0"/>
      <button command="" commandUp="" enableSource="" frame-style="" label="phrase-2" parameter="Command.data" show_frame="false" show_title="false" style="" title="Title" value="1" valueUp="0" x="180" select_x="1" y="240" select_y="0"/>
      <button command="" commandUp="" enableSource="" frame-style="" label="phrase-3" parameter="Command.data" show_frame="false" show_title="false" style="" title="Title" value="1" valueUp="0" x="300" select_x="2" y="240" select_y="0"/>
      <button command="" commandUp="" enableSource="" frame-style="" label="phrase-4" parameter="Command.data" show_frame="false" show_title="false" style="" title="Title" value="1" valueUp="0" x="420" select_x="3" y="240" select_y="0"/>
      <button command="" commandUp="" enableSource="" frame-style="" label="phrase-5" parameter="Command.data" show_frame="false" show_title="false" style="" title="Title" value="1" valueUp="0" x="540" select_x="4" y="240" select_y="0"/>
      <button command="" commandUp="" enableSource="" frame-style="" label="phrase-6" parameter="Command.data" show_frame="false" show_title="false" style="" title="Title" value="1" valueUp="0" x="660" select_x="5" y="240" select_y="0"/>
      <slider-horizontal count="1" frame-style="" height="200" labels="" max="10" min="0" parameter="EpiSpeech.scale_volume" select_x="0" show_frame="false" show_title="true" show_values="true" step="0.01" style="" title="Scale Volume Output" width="200" x="1000" y="240"/>
      <slider-horizontal count="1" frame-style="" height="200" labels="" max="500" min="-500" parameter="EpiSpeech.lag" select_x="0" show_frame="false" show_title="true" show_values="true" step="0.01" style="" title="Lag" width="200" x="1000" y="460"/>
      <slider-horizontal count="1" frame-style="" height="121" labels="" max="1" min="0" parameter="Attribute2.data" select_x="0" show_frame="false" show_title="true" show_values="false" step="0.01" style="" title="Attribute 2" width="101" x="420" y="360"/>
      <switch frame-style="" height="41" labels="Inhibition" parameter="Inhibition.data" show_frame="false" show_title="false" style="" title="Switch Title" value="1" width="101" x="60" select_x="0" y="920" select_y="0"/>
      <switch frame-style="" height="21" labels="red" parameter="Attribute1.data" show_frame="false" show_title="false" style="" title="Red" value="1" width="101" x="60" select_x="0" y="400" select_y="0"/>
      <switch frame-style="" height="21" labels="green" parameter="Attribute1.data" show_frame="false" show_title="false" style="" title="Green" value="1" width="101" x="60" select_x="1" y="420" select_y="0"/>
      <switch frame-style="" height="21" labels="blue" parameter="Attribute1.data" show_frame="false" show_title="false" style="" title="Blue" value="1" width="101" x="60" select_x="2" y="440" select_y="0"/>
      <text frame-style="" height="101" parameter="" postfix="" prefix="" select_source="" separator="" show_frame="false" show_title="true" strings="" style="" text="" title="Attribute 1" width="101" x="60" y="360"/>
   </view>
</group>
