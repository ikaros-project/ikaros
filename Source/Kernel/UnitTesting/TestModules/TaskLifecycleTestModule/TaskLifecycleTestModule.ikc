<class internal="true" name="TaskLifecycleTestModule" description="Synchronous task lifecycle test module">
    <parameter name="duration" type="number" default="0" description="Seconds spent in Tick." />
    <parameter name="fail" type="bool" default="false" description="Throw after the delay." />
    <parameter name="label" type="string" default="Task" description="Label included in lifecycle messages." />
    <parameter name="output_value" type="number" default="1" description="Value written at the end of Tick." />
    <output name="OUTPUT" size="1" description="Value written at the end of Tick." />
</class>
