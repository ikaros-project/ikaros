<group
    name="TestScopedStateLoadRemap"
    description="Test scoped state load remaps module paths"
    webui_port="8171"
    http_start_delay="0.2"
    http_requests="stop||savestate?filename=test_171_scoped_state_source&amp;module=TestScopedStateLoadRemap.SourceMemory||resetstate?module=TestScopedStateLoadRemap.TargetMemory||loadstate?filename=test_171_scoped_state_source&amp;module=TestScopedStateLoadRemap.TargetMemory||savestate?filename=test_171_scoped_state_result||quit"
    expected_output_contains="Loaded state from /Users/cba/ikaros/UserData/test_171_scoped_state_source.state into TestScopedStateLoadRemap.TargetMemory"
    expected_file_exists="UserData/test_171_scoped_state_source.state||UserData/test_171_scoped_state_result.state"
    expected_file_contains="&quot;scope&quot;: &quot;TestScopedStateLoadRemap.SourceMemory&quot;||&quot;TestScopedStateLoadRemap.TargetMemory.bias&quot;||&quot;type&quot;: &quot;float&quot;||&quot;value&quot;: 0.25||&quot;TestScopedStateLoadRemap.TargetMemory.gain&quot;||&quot;value&quot;: 1.5||&quot;TestScopedStateLoadRemap.TargetMemory.steps&quot;||&quot;value&quot;: 42||&quot;TestScopedStateLoadRemap.TargetMemory.active&quot;||&quot;value&quot;: false||&quot;TestScopedStateLoadRemap.TargetMemory.label&quot;||&quot;value&quot;: &quot;trained&quot;"
    cleanup_expected_files="true"
>
    <module name="SourceMemory" class="PersistentStateTestModule" use_scalar="true" write="true" />
    <module name="TargetMemory" class="PersistentStateTestModule" use_scalar="true" write="false" />
</group>
