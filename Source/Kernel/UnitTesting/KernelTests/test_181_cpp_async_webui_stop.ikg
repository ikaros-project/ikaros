<group internal="true" name="TestCppAsyncWebUIStop" description="Test WebUI stop while C++ async work is running" start="true" stop="100" webui_port="8181" http_start_delay="0.05" http_requests="stop" http_terminate_after_requests="true" expected_output_contains="stop">
    <module class="Constant" name="Input" data="2"/>
    <module class="AsyncLifecycleTestModule" name="Worker" async="yes" duration="2"/>
    <module class="Print" name="Print"/>

    <connection source="Input.OUTPUT" target="Worker.X" delay="0"/>
    <connection source="Worker.Y" target="Print.INPUT" delay="0"/>
</group>
