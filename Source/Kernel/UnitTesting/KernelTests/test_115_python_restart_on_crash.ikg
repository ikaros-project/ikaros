<group name="TestPythonRestartOnCrash" description="Test that a crashed python worker can restart and continue producing output" start="true" stop="4" webui_port="8107">
    <module class="Constant" name="InputValues" data="4,5,6"/>
    <module class="CrashOnceThenRecover" name="Recover" restart_on_crash="true" on_error="log"/>
    <module class="Print" name="Print"/>

    <connection source="InputValues.OUTPUT" target="Recover.X" delay="0"/>
    <connection source="Recover.Y" target="Print.INPUT" delay="0"/>
</group>
