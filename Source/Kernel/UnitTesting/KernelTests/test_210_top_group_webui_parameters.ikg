<group internal="true"
    name="TestTopGroupWebUIParameters"
    description="Test top-group WebUI parameter overrides"
    start="true"
    stop="3"
    tick_duration="0.01"
    webui_port="8210"
    webui_req_int="0.234"
    snapshot_interval="12.5"
    rgb_quality="13"
    gray_quality="17"
    webui_log_buffer_limit="2"
    http_start_delay="0.3"
    http_requests="assert_webui_parameters:update/TestTopGroupWebUIParameters?data=snapshot_interval,rgb_quality,gray_quality,webui_log_buffer_limit:0.234:12.5:13:17:2||assert_log_fanout:update:Top-group parameter marker:2"
    http_terminate_after_requests="true">
    <module class="NotifyTester"
        name="LogSource"
        notify_level="warning"
        notify_message="Top-group parameter marker"
        notify_tick="1"
        repeat="true" />
</group>
