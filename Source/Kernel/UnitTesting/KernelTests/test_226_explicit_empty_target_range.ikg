<group internal="true"
    name="TestExplicitEmptyTargetRange"
    description="Do not expand an explicitly empty target selector as a wildcard"
    expected_exit="1"
    expected_output_contains="Connection could not be resolved">
    <module class="Constant" name="Source" data="1,2" />
    <module class="Print" name="Sink" />

    <connection source="Source.OUTPUT[0:2]" target="Sink.INPUT[0:0]" />
</group>
