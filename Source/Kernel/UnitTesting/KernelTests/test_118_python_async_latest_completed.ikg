<group internal="true" name="TestPythonAsyncLatestCompleted" description="Test that async python outputs only update when a worker run completes" start="true" stop="20" webui_port="8110">
    <module class="Constant" name="InputValues" data="1"/>
    <module class="AsyncLatestCompleted" name="Async" async="yes"/>
    <module class="Print" name="Print"/>

    <connection source="InputValues.OUTPUT" target="Async.X" delay="0"/>
    <connection source="Async.Y" target="Print.INPUT" delay="0"/>
</group>
