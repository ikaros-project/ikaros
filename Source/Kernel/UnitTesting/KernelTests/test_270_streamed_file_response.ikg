<group internal="true"
    name="TestStreamedFileResponse"
    description="Stream a large read-only WebUI file without buffering the whole file"
    start="true"
    stop="1"
    check_sum="1034"
    webui_port="8270"
    http_ready_path="auth"
    http_requests="assert_read_only_file_response:/Models/glb/Torso.glb:../../../WebUI/Models/glb/Torso.glb"
    http_terminate_after_requests="true">
    <module class="System" name="System" />
</group>
