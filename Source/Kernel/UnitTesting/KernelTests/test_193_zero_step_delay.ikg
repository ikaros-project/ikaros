<group internal="true"
    name="TestZeroStepDelay"
    description="Reject zero-step connection delay ranges"
    expected_exit="1"
    expected_output_contains="delay range must have a positive increment">
    <module class="Constant" name="Source" data="1" />
    <module class="Print" name="Sink" />
    <connection source="Source.OUTPUT" target="Sink.INPUT" delay="[0:3:0]" />
</group>
