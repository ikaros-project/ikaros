<group internal="true" name="TestAsyncProfilingSnapshot" description="Test demand-driven profiling while an asynchronous module is active" start="true" stop="100000" tick_duration="0.001" webui_port="8213" http_start_delay="0.05" http_requests="assert_async_profiling:TestAsyncProfilingSnapshot.Worker:500" http_terminate_after_requests="true">

    <module class="Constant" name="Source" data="1" />
    <module class="AsyncLifecycleTestModule" name="Worker" async="yes" duration="0.002" />

    <connection source="Source.OUTPUT" target="Worker.X" />

</group>
