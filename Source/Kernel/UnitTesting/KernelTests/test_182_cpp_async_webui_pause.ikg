<group internal="true" name="TestCppAsyncWebUIPause" description="Test WebUI pause waits for C++ async work to finish" start="true" stop="100" webui_port="8182" http_start_delay="0.05" http_requests="pause" http_terminate_after_requests="true" expected_output_contains="pause||&quot;running&quot;: false">
    <module class="Constant" name="Input" data="2"/>
    <module class="AsyncLifecycleTestModule" name="Worker" async="yes" duration="2"/>
    <module class="Print" name="Print"/>

    <connection source="Input.OUTPUT" target="Worker.X" delay="0"/>
    <connection source="Worker.Y" target="Print.INPUT" delay="0"/>
</group>
