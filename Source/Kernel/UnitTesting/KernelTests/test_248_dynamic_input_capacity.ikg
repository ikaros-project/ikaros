<group internal="true"
    name="TestDynamicInputCapacity"
    description="Defer an input-dependent dynamic output capacity until its source shape resolves"
    check_sum="413"
    expected_output_contains="DYNAMIC INPUT CAPACITY RESOLVED">
    <module class="DynamicInputCapacityModule" name="AConsumer" />
    <module class="Constant" name="ZSource" data="1,2,3;4,5,6" />

    <connection source="ZSource.OUTPUT" target="AConsumer.X" delay="0" />
</group>
