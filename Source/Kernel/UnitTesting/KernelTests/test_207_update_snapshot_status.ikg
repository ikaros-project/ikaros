<group internal="true"
    name="TestUpdateSnapshotStatus"
    description="Test WebUI update status and data come from the same snapshot"
    tick_duration="0.001"
    webui_port="8207"
    http_start_delay="0.01"
    http_requests="play/TestUpdateSnapshotStatus?data=Source.OUTPUT||sleep:0.06||assert_snapshot_tick:update/TestUpdateSnapshotStatus?data=Source.OUTPUT:Source.OUTPUT"
    http_terminate_after_requests="true">
    <module class="DelaySequenceSource" name="Source" />
    <module class="TaskLifecycleTestModule" name="Slow" duration="0.05" label="Slow" />
</group>
