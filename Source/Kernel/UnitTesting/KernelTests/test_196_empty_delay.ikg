<group internal="true"
    name="TestEmptyDelay"
    description="Reject empty connection delay ranges"
    expected_exit="1"
    expected_output_contains="delay range must not be empty">
    <module class="Constant" name="Source" data="1" />
    <module class="Print" name="Sink" />
    <connection source="Source.OUTPUT" target="Sink.INPUT" delay="[]" />
</group>
