<group
    name="Test_45"
    description="Test multi-level inherited expression uses defining group context"
    check_sum="222632"

    x = "2"
>

    <group
        name="G1"
        a = "@x+1"
    >
        <module
            name="M1"
            class="KernelTestModule"
            x = "100"
        />
    </group>

    <module name="Const" class="Constant" data="9, 8, 7" />
    <connection source="Const.OUTPUT" target="G1.M1.INPUT" />

</group>
