<group name="OutputImageFormats"
       description="OutputImage writes JPEG and numbered PNG files"
       start="true"
       stop="2"
       check_sum="1859819"
       expected_file_exists="UserData/test_291_output_image.jpg||UserData/test_291_output_image_07.png||UserData/test_291_output_image_08.png||UserData/test_291_output_image_trigger_99.png"
       expected_output_not_contains="OutputImage sequence stopped"
       cleanup_expected_files="true">
    <module name="ColorSource"
            class="InputImage"
            filename="../Examples/Media/colorrobot.jpg" />
    <module name="JPEGOutput"
            class="OutputImage"
            filename="test_291_output_image.jpg"
            quality="85" />
    <module name="GraySource"
            class="Constant"
            data="0,0.25;0.75,1" />
    <module name="PNGOutput"
            class="OutputImage"
            filename="test_291_output_image_##.png"
            start_index="7" />
    <module name="Trigger"
            class="Constant"
            data="1" />
    <module name="TriggeredPNGOutput"
            class="OutputImage"
            filename="test_291_output_image_trigger_##.png"
            start_index="99"
            single_trigger="yes" />

    <connection source="ColorSource.OUTPUT" target="JPEGOutput.INPUT" />
    <connection source="GraySource.OUTPUT" target="PNGOutput.INPUT" />
    <connection source="GraySource.OUTPUT" target="TriggeredPNGOutput.INPUT" />
    <connection source="Trigger.OUTPUT" target="TriggeredPNGOutput.WRITE" />
</group>
