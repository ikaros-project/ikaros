<group name="TestPythonZeroArgHooks" description="Test zero-argument init, tick, and shutdown hooks" start="true" stop="1" webui_port="8136" expected_output_contains="INPUT = {10}" expected_file_exists="/tmp/ikaros_zero_arg_hooks_marker.txt">
    <module class="Constant" name="InputValues" data="1,2,3,4"/>
    <module class="ZeroArgHooks" name="Hooks"/>
    <module class="Print" name="Print"/>

    <connection source="InputValues.OUTPUT" target="Hooks.X" delay="0"/>
    <connection source="Hooks.Y" target="Print.INPUT" delay="0"/>
</group>
