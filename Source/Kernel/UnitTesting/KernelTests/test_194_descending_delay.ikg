<group internal="true"
    name="TestDescendingDelay"
    description="Reject descending connection delay ranges"
    expected_exit="1"
    expected_output_contains="delay range must be an ascending, non-empty range">
    <module class="Constant" name="Source" data="1" />
    <module class="Print" name="Sink" />
    <connection source="Source.OUTPUT" target="Sink.INPUT" delay="[3:0]" />
</group>
