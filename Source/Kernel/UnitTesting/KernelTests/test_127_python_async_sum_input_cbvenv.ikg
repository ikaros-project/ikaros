<group name="TestPythonAsyncSumInputCbVenv" description="Test async python sum using cbvenv shared-memory transport" start="true" stop="10" webui_port="8127" expected_output_contains="INPUT = {10}">
    <module class="Constant" name="InputValues" data="1,2,3,4"/>
    <module class="AsyncSumInput" name="Sum" execution_mode="async" python_executable="/Users/cba/cbvenv/bin/python"/>
    <module class="Print" name="Print"/>

    <connection source="InputValues.OUTPUT" target="Sum.X" delay="0"/>
    <connection source="Sum.Y" target="Print.INPUT" delay="0"/>
</group>
