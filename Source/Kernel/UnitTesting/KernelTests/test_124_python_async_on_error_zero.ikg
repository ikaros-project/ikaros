<group name="TestPythonAsyncOnErrorZero" description="Test that async python failures can zero outputs and continue" start="true" stop="40" webui_port="8224" expected_output_contains="INPUT = {5}||INPUT = {0}||async zero failure">
    <module class="AsyncErrorZero" name="Async" execution_mode="async" on_error="zero"/>
    <module class="Print" name="Print"/>

    <connection source="Async.Y" target="Print.INPUT" delay="0"/>
</group>
