<group internal="true"
    name="TestReversedTargetSelectorBounds"
    description="Reject inferred target selector stops below their starts during setup"
    expected_exit="1"
    expected_output_contains="Connection target selector must have non-negative, ordered bounds">
    <module class="Constant" name="Source" data="1,2" />
    <module class="Print" name="Sink" />

    <connection source="Source.OUTPUT" target="Sink.INPUT[2:1]" />
</group>
